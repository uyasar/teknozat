{{!< default}}

{{#post}}
<div class="page-container">
    <article class="page {{post_class}}">
        <header class="page-header">
            <h1 class="page-title">{{title}}</h1>
            {{#if custom_excerpt}}
            <p class="page-excerpt">{{custom_excerpt}}</p>
            {{/if}}
            <div class="page-header-rule"></div>
        </header>

        {{#if feature_image}}
        <figure class="post-feature-figure">
            <img
                class="post-feature-image"
                src="{{img_url feature_image size="l"}}"
                alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
            >
            {{#if feature_image_caption}}
            <figcaption class="post-feature-caption">{{feature_image_caption}}</figcaption>
            {{/if}}
        </figure>
        {{/if}}

        <section class="post-content gh-content">
            {{content}}
        </section>
    </article>
</div>
{{/post}}
