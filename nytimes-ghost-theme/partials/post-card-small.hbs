<article class="post-card-small {{post_class}}">
    <div class="post-card-small-content">
        {{#if tags}}
        <div class="post-card-tags">
            {{#foreach tags limit="1"}}
                <a href="{{url}}" class="post-card-tag">{{name}}</a>
            {{/foreach}}
        </div>
        {{/if}}
        <h3 class="post-card-small-title">
            <a href="{{url}}" class="post-card-title-link">{{title}}</a>
        </h3>
        <footer class="post-card-footer">
            <time class="post-card-date" datetime="{{date format="YYYY-MM-DD"}}">{{date format="MMMM D, YYYY"}}</time>
        </footer>
    </div>
    {{#if feature_image}}
    <a href="{{url}}" class="post-card-small-image-link" tabindex="-1" aria-hidden="true">
        <img
            class="post-card-small-image"
            src="{{img_url feature_image size="xs"}}"
            alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
            loading="lazy"
            width="100"
            height="100"
        >
    </a>
    {{/if}}
</article>
