<article class="post-card {{#if featured}}post-card-featured{{/if}} {{post_class}}">
    {{#if feature_image}}
    <a href="{{url}}" class="post-card-image-link" tabindex="-1" aria-hidden="true">
        <img
            class="post-card-image"
            srcset="{{img_url feature_image size="s"}} 300w,
                    {{img_url feature_image size="m"}} 600w,
                    {{img_url feature_image size="l"}} 1000w"
            sizes="(max-width: 700px) 100vw, 350px"
            src="{{img_url feature_image size="m"}}"
            alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
            loading="lazy"
        >
    </a>
    {{/if}}
    <div class="post-card-content">
        {{#if tags}}
        <div class="post-card-tags">
            {{#foreach tags limit="1"}}
                <a href="{{url}}" class="post-card-tag">{{name}}</a>
            {{/foreach}}
        </div>
        {{/if}}
        <h2 class="post-card-title">
            <a href="{{url}}" class="post-card-title-link">{{title}}</a>
        </h2>
        {{#if custom_excerpt}}
            <p class="post-card-excerpt">{{custom_excerpt}}</p>
        {{else}}
            <p class="post-card-excerpt">{{excerpt words="25"}}</p>
        {{/if}}
        <footer class="post-card-footer">
            <div class="post-card-byline">
                {{#foreach authors limit="2"}}
                    <span class="post-card-author">By <a href="{{url}}" class="post-card-author-link">{{name}}</a></span>{{#unless @last}}, {{/unless}}
                {{/foreach}}
            </div>
            <time class="post-card-date" datetime="{{date format="YYYY-MM-DD"}}">{{date format="MMMM D, YYYY"}}</time>
        </footer>
    </div>
</article>
