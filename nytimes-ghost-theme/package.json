{
  "name": "nytimes-ghost-theme",
  "description": "A Ghost theme inspired by The New York Times",
  "version": "1.0.0",
  "engines": {
    "ghost": ">=6.0.0"
  },
  "license": "MIT",
  "author": {
    "name": "Ghost Theme Authors",
    "email": "hello@example.com"
  },
  "keywords": [
    "ghost-theme",
    "news",
    "newspaper",
    "nytimes"
  ],
  "config": {
    "posts_per_page": 10,
    "image_sizes": {
      "xxs": {
        "width": 30
      },
      "xs": {
        "width": 100
      },
      "s": {
        "width": 300
      },
      "m": {
        "width": 600
      },
      "l": {
        "width": 1000
      },
      "xl": {
        "width": 2000
      }
    },
    "card_assets": true,
    "custom": {
      "show_featured_section": {
        "type": "boolean",
        "default": true,
        "description": "Show the lead/featured stories section on the homepage"
      },
      "accent_color": {
        "type": "color",
        "default": "#d0021b",
        "description": "Accent color used for tags, links, and highlights"
      }
    }
  }
}
