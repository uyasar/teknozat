{
  "name": "nytimes-ghost-theme",
  "description": "A Ghost theme inspired by The New York Times",
  "version": "1.0.0",
  "engines": {
    "ghost": ">=5.0.0"
  },
  "license": "MIT",
  "keywords": [
    "ghost-theme",
    "news",
    "newspaper",
    "nytimes"
  ],
  "config": {
    "posts_per_page": 10,
    "image_sizes": {
      "xxs": {
        "width": 30
      },
      "xs": {
        "width": 100
      },
      "s": {
        "width": 300
      },
      "m": {
        "width": 600
      },
      "l": {
        "width": 1000
      },
      "xl": {
        "width": 2000
      }
    },
    "card_assets": true,
    "custom": {
      "navigation_layout": {
        "type": "select",
        "options": ["Logo on left", "Logo in the middle"],
        "default": "Logo in the middle",
        "description": "Layout of the header navigation"
      },
      "show_featured_section": {
        "type": "boolean",
        "default": true,
        "description": "Show featured posts section on homepage"
      },
      "accent_color": {
        "type": "color",
        "default": "#d0021b",
        "description": "Accent color for links and highlights"
      }
    }
  }
}
